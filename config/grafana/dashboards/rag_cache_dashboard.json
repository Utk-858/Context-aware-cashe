  "panels": [
    {
      "type": "stat",
      "title": "L1 Hit Rate (1m)",
      "id": 1,
      "gridPos": {"h": 4, "w": 4, "x": 0, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus_ds"},
      "targets": [
        {
          "expr": "(sum(rate(rag_cache_l1_hits_total[1m])) or vector(0)) / ((sum(rate(rag_cache_l1_hits_total[1m])) + sum(rate(rag_cache_l1_misses_total[1m]))) or vector(1))",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"value": null, "color": "red"},
              {"value": 0.5, "color": "orange"},
              {"value": 0.8, "color": "green"}
            ]
          }
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "textMode": "valueAndName"
      }
    },
    {
      "type": "stat",
