      "targets": [
        {
          "expr": "(sum(rate(rag_cache_l2_misses_total[1m])) or vector(0)) / ((sum(rate(rag_cache_l1_hits_total[1m])) + sum(rate(rag_cache_l2_hits_total[1m])) + sum(rate(rag_cache_l2_misses_total[1m]))) or vector(1))",
