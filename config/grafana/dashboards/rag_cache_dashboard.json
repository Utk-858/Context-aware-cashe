    {
      "type": "timeseries",
      "title": "Average Request Latency by Cache Status (1m Avg)",
      "id": 6,
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
      "datasource": {"type": "prometheus", "uid": "prometheus_ds"},
      "targets": [
        {
          "expr": "sum(rate(rag_cache_total_request_latency_seconds_sum[1m])) by (cache_hit) / sum(rate(rag_cache_total_request_latency_seconds_count[1m])) by (cache_hit)",
          "refId": "A",
          "legendFormat": "Cache Hit: {{cache_hit}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth"
          }
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Component Latency Breakdown (1m Avg)",
      "id": 7,
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
      "datasource": {"type": "prometheus", "uid": "prometheus_ds"},
      "targets": [
        {
          "expr": "sum(rate(rag_cache_faiss_search_latency_seconds_sum[1m])) / sum(rate(rag_cache_faiss_search_latency_seconds_count[1m]))",
          "refId": "FAISS",
          "legendFormat": "FAISS Search"
        },
        {
          "expr": "sum(rate(rag_cache_embedding_latency_seconds_sum[1m])) / sum(rate(rag_cache_embedding_latency_seconds_count[1m]))",
          "refId": "Embedding",
          "legendFormat": "Embedding"
        },
        {
          "expr": "sum(rate(rag_cache_decision_engine_latency_seconds_sum[1m])) / sum(rate(rag_cache_decision_engine_latency_seconds_count[1m]))",
          "refId": "DecisionEngine",
          "legendFormat": "Decision Engine"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth"
          }
        }
      }
    },
